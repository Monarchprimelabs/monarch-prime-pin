{
  "cli": {
    "version": ">= 19.0.8",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "ios-production": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_MONETIZATION_ENABLED": "true"
      }
    },
    "android-production": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_MONETIZATION_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6770808426"
      }
    },
    "ios-production": {
      "ios": {
        "ascAppId": "6770808426"
      }
    }
  }
}
